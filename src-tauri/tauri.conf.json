{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "llmgui",
  "version": "2026.7.19-2",
  "identifier": "com.maxr777.llmgui",
  "build": {
    "beforeDevCommand": "corepack pnpm@9.15.9 dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "corepack pnpm@9.15.9 build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "llmgui",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "wix": {
        "version": "26.7.19.2"
      }
    },
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
